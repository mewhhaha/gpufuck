{
  "unstable": ["webgpu"],
  "imports": {
    "@mewhhaha/baba/runtime/generated-wasm": "jsr:@mewhhaha/baba@4.0.0/runtime/generated-wasm"
  },
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "useUnknownInCatchVariables": true,
    "noFallthroughCasesInSwitch": true
  },
  "fmt": {
    "exclude": ["language/lazuli/generated"],
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false
  },
  "tasks": {
    "compile": "deno run --allow-read cli.ts",
    "compile:lazuli": "deno run --allow-read lazuli_cli.ts compile",
    "generate:lazuli": "deno run --allow-read --allow-write jsr:@mewhhaha/baba@4.0.0/cli language/lazuli/grammar.baba --out language/lazuli/generated --name lazuli --root module --target wasm",
    "check": "deno check mod.ts cli.ts lazuli_cli.ts tests/*.ts",
    "fmt": "deno fmt --check",
    "lint": "deno lint",
    "run:lazuli": "deno run --allow-read lazuli_cli.ts run",
    "test": "deno test --allow-read"
  }
}
